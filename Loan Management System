import java.io.*;
import java.util.*;
public class LoanManagementSystem implements Serializable {
    static class Loan implements Serializable {
        int loanId;
        String customerName;
        double loanAmount;
        double interestRate;
        int tenure;
        double emi;
        String status;
        double remainingAmount;
        Loan(int loanId, String customerName, double loanAmount, double interestRate, int tenure) {
            this.loanId = loanId;
            this.customerName = customerName;
            this.loanAmount = loanAmount;
            this.interestRate = interestRate;
            this.tenure = tenure;
            this.status = "Pending";
            this.emi = calculateEMI();
            this.remainingAmount = loanAmount;
        }
        double calculateEMI() {
            double r = interestRate / (12 * 100);
            return (loanAmount * r * Math.pow(1 + r, tenure)) /
                   (Math.pow(1 + r, tenure) - 1);
        }
        void display() {
            System.out.println("Loan ID: " + loanId);
            System.out.println("Customer: " + customerName);
            System.out.println("Amount: " + loanAmount);
            System.out.println("Interest Rate: " + interestRate);
            System.out.println("Tenure: " + tenure);
            System.out.println("EMI: " + emi);
            System.out.println("Status: " + status);
            System.out.println("Remaining Amount: " + remainingAmount);
            System.out.println("----------------------------");
        }
    }
    static ArrayList<Loan> loans = new ArrayList<>();
    static final String FILE_NAME = "loans.dat";

    static void saveLoans() {
        try {
            ObjectOutputStream oos = new ObjectOutputStream(new FileOutputStream(FILE_NAME));
            oos.writeObject(loans);
            oos.close();
        } catch (Exception e) {
            System.out.println("Error saving file!");
        }
    }
    @SuppressWarnings("unchecked")
    static void loadLoans() {
        try {
            ObjectInputStream ois = new ObjectInputStream(new FileInputStream(FILE_NAME));
            loans = (ArrayList<Loan>) ois.readObject();
            ois.close();
        } catch (Exception e) {
            loans = new ArrayList<>();
        }
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        loadLoans();

        while (true) {
            System.out.println("\n--- Loan Management System ---");
            System.out.println("1. Apply for Loan");
            System.out.println("2. View Loans");
            System.out.println("3. Approve/Reject Loan");
            System.out.println("4. Pay EMI");
            System.out.println("5. Exit");
            System.out.print("Enter choice: ");
            int choice = sc.nextInt();
            switch (choice) {
                case 1:
                    System.out.print("Enter Loan ID: ");
                    int id = sc.nextInt();
                    sc.nextLine();
                    System.out.print("Enter Customer Name: ");
                    String name = sc.nextLine();
                    System.out.print("Enter Loan Amount: ");
                    double amount = sc.nextDouble();
                    System.out.print("Enter Interest Rate: ");
                    double rate = sc.nextDouble();
                    System.out.print("Enter Tenure (months): ");
                    int tenure = sc.nextInt();
                    Loan loan = new Loan(id, name, amount, rate, tenure);
                    loans.add(loan);
                    saveLoans();
                    System.out.println("Loan Applied Successfully!");
                    break;
                case 2:
                    if (loans.isEmpty()) {
                        System.out.println("No loans available!");
                    } else {
                        for (Loan l : loans) {
                            l.display();
                        }
                    }
                    break;
                case 3:
                    System.out.print("Enter Loan ID: ");
                    int searchId = sc.nextInt();

                    boolean found = false;
                    for (Loan l : loans) {
                        if (l.loanId == searchId) {
                            System.out.print("Approve (A) / Reject (R): ");
                            char ch = sc.next().charAt(0);

                            if (ch == 'A' || ch == 'a') {
                                l.status = "Approved";
                            } else {
                                l.status = "Rejected";
                            }

                            saveLoans();
                            System.out.println("Updated Successfully!");
                            found = true;
                            break;
                        }
                    }
                    if (!found) System.out.println("Loan not found!");
                    break;
                case 4:
                    System.out.print("Enter Loan ID: ");
                    int payId = sc.nextInt();

                    boolean paid = false;
                    for (Loan l : loans) {
                        if (l.loanId == payId && l.status.equals("Approved")) {
                            l.remainingAmount -= l.emi;

                            if (l.remainingAmount <= 0) {
                                l.remainingAmount = 0;
                                System.out.println("Loan Fully Repaid!");
                            } else {
                                System.out.println("EMI Paid. Remaining: " + l.remainingAmount);
                            }
                            saveLoans();
                            paid = true;
                            break;
                        }
                    }
                    if (!paid) System.out.println("Loan not found or not approved!");
                    break;
                case 5:
                    System.out.println("Exiting...");
                    return;
                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
