import java.io.*;
import java.util.*;
	class Product {
	    String name;
	    double price;
	    int quantity;
	    Product(String name, double price, int quantity) {
	        this.name = name;
	        this.price = price;
	        this.quantity = quantity;
	    }
	    double getTotal() {
	        return price * quantity;
	    }
	    public String toString() {
	        return name + " | " + price + " | " + quantity + " | " + getTotal();
	    }
	}
	public class billingsystem {
	    static ArrayList<Product> cart = new ArrayList<>();
	    static final String FILE_NAME = "invoice.txt";
	    static void addItem(Scanner sc) {
	        sc.nextLine();
	        System.out.print("Enter product name: ");
	        String name = sc.nextLine();
	        System.out.print("Enter price: ");
	        double price = sc.nextDouble();
	        System.out.print("Enter quantity: ");
	        int qty = sc.nextInt();
	        cart.add(new Product(name, price, qty));
	        System.out.println("Item added!");
	    }
	    static double calculateTotal() {
	        double total = 0;
	        for (Product p : cart) {
	            total += p.getTotal();
	        }
	        return total;
	    }
	    static double applyDiscount(double total) {
	        if (total > 1000) {
	            System.out.println("10% Discount Applied!");
	            return total * 0.9;
	        }
	        return total;
	    }
	    static void generateBill() {
	        System.out.println("\n----- BILL -----");
	        for (Product p : cart) {
	            System.out.println(p);
	        }
	        double total = calculateTotal();
	        double finalAmount = applyDiscount(total);

	        System.out.println("----------------");
	        System.out.println("Total: " + total);
	        System.out.println("Final Amount: " + finalAmount);
	    }
	    static void saveInvoice(double finalAmount) {
	        try (PrintWriter pw = new PrintWriter(new FileWriter(FILE_NAME))) {
	            pw.println("----- BILL -----");
	            for (Product p : cart) {
	                pw.println(p);
	            }
	            pw.println("Final Amount: " + finalAmount);
	            System.out.println("Invoice saved to file!");
	        } catch (Exception e) {
	            System.out.println("Error saving file!");
	        }
	    }
	    public static void main(String[] args) {
	        Scanner sc = new Scanner(System.in);
	        while (true) {
	            System.out.println("\n1.Add Item 2.Generate Bill 3.Exit");
	            int choice = sc.nextInt();
	            switch (choice) {
	                case 1:
	                    addItem(sc);
	                    break;
	                case 2:
	                    generateBill();
	                    double total = calculateTotal();
	                    double finalAmount = applyDiscount(total);
	                    saveInvoice(finalAmount);
	                    break;
	                case 3:
	                    System.out.println("Thank you!");
	                    return;
	                default:
	                    System.out.println("Invalid choice!");
	            }
	        }
	    }
	}
